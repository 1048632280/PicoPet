{
  "name": "picopet",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "test": "vitest",
    "check": "pnpm test -- --run && pnpm build && cargo test --manifest-path src-tauri/Cargo.toml",
    "check:windows": "powershell -ExecutionPolicy Bypass -File scripts/windows-release-smoke.ps1",
    "check:windows:release": "powershell -ExecutionPolicy Bypass -File scripts/windows-release-smoke.ps1 -Release",
    "artifact:windows": "powershell -ExecutionPolicy Bypass -File scripts/assert-windows-artifacts.ps1",
    "portable:windows": "powershell -ExecutionPolicy Bypass -File scripts/package-windows-portable.ps1",
    "memory:windows": "powershell -ExecutionPolicy Bypass -File scripts/windows-memory-baseline.ps1",
    "release:windows:gate": "powershell -ExecutionPolicy Bypass -File scripts/windows-release-gate.ps1",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.0.0"
}
